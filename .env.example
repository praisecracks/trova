# Supabase configuration
# Get these values from your Supabase project dashboard:
# Project Settings → API → Project URL and Publishable (anon) key
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-publishable-anon-key-here"

# Public Trova domain used for generated pay and tracking links
VITE_TROVA_PUBLIC_URL="https://trova.co"